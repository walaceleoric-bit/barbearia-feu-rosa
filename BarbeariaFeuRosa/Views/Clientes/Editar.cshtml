@model BarbeariaFeuRosa.Models.Cliente

@{
    ViewData["Title"] = "Editar Cliente";

    string usuarioLogin = ViewBag.UsuarioLogin ?? "";
    string senha = ViewBag.Senha ?? "";
}

<div class="container p-4">

    <div class="d-flex justify-content-between align-items-center">
        <h2>Editar Cliente</h2>

        <a href="/Clientes" class="btn btn-outline-dark">
            ← Voltar
        </a>
    </div>

    <hr />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            Verifique os campos abaixo.
        </div>
    }

    <form method="post">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label>Nome</label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>WhatsApp</label>
            <input asp-for="WhatsApp"
                   id="whatsapp"
                   class="form-control"
                   inputmode="numeric"
                   placeholder="(00) 00000-0000" />
            <span asp-validation-for="WhatsApp" class="text-danger"></span>
        </div>

        <hr />

        <h5>Login do Cliente</h5>

        <div class="mb-3">
            <label>Usuário/Login</label>
            <input name="usuarioLogin"
                   value="@usuarioLogin"
                   class="form-control"
                   required />
        </div>

        <div class="mb-3">
            <label>Senha</label>
            <input name="senha"
                   value="@senha"
                   maxlength="6"
                   inputmode="numeric"
                   class="form-control"
                   required />
            <small class="text-muted">
                Máximo 6 caracteres.
            </small>
        </div>

        <button type="submit" class="btn btn-dark">
            Salvar Alterações
        </button>

        <a href="/Clientes" class="btn btn-outline-secondary">
            Cancelar
        </a>

    </form>

</div>

<script>
    document.getElementById("whatsapp").addEventListener("input", function(e) {
        let v = e.target.value.replace(/\D/g, '');

        if (v.length > 11)
            v = v.substring(0, 11);

        if (v.length > 6)
            v = v.replace(/^(\d{2})(\d{5})(\d+)/, '($1) $2-$3');
        else if (v.length > 2)
            v = v.replace(/^(\d{2})(\d+)/, '($1) $2');

        e.target.value = v;
    });
</script>