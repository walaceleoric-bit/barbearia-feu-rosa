@{
    ViewData["Title"] = "Dashboard";

    var agendaHoje =
        ViewBag.AgendaHoje as List<BarbeariaFeuRosa.Models.Agendamento>;

    var slug =
        Context.Session.GetString("BarbeariaSlug");
}

<div class="container-fluid">

    <div class="row">

        <div class="col-2 bg-dark text-white vh-100 p-3 d-flex flex-column">

            <div>

                <div class="text-center mb-3">

                    @if (!string.IsNullOrEmpty(ViewBag.LogoUrl))
                    {
                        <img src="@ViewBag.LogoUrl"
                             style="max-height: 90px; max-width: 100%; object-fit: contain;"
                             class="mb-2" />
                    }

                    <h5 class="fw-bold">
                        @ViewBag.NomeBarbearia
                    </h5>

                </div>

                <hr />

                <a href="/Dashboard"
                   class="text-white text-decoration-none d-block mb-3 menu-ativo">

                    🏠 Dashboard

                </a>

                <a href="/Agenda"
                   class="text-white text-decoration-none d-block mb-3">

                    📅 Agenda

                </a>

                <a href="/Clientes"
                   class="text-white text-decoration-none d-block mb-3">

                    👤 Clientes

                </a>

                <a href="/Barbeiros"
                   class="text-white text-decoration-none d-block mb-3">

                    ✂ Barbeiros

                </a>

                <a href="/Financeiro"
                   class="text-white text-decoration-none d-block mb-3">

                    💰 Financeiro

                </a>

                <a href="/@(slug)/Relatorios"
                   class="text-white text-decoration-none d-block mb-3">

                    📊 Relatórios

                </a>

                <a href="/Configuracoes"
                   class="text-white text-decoration-none d-block mb-3">

                    ⚙ Configurações

                </a>

                <a href="/ClienteHome/Preview"
                   target="_blank"
                   class="text-white text-decoration-none d-block mb-3">

                    <div class="d-flex justify-content-between align-items-center">

                        <span>
                            👁 Tela do Cliente
                        </span>

                        <span class="badge bg-success px-2">

                            🟢 Ao vivo

                        </span>

                    </div>

                </a>

            </div>


            <div class="mt-auto">

                <hr />

                <a href="/Auth/Sair"
                   class="text-white text-decoration-none d-block fw-bold">

                    🚪 Sair

                </a>

            </div>

        </div>


        <div class="col-10 p-4">

            <h2>Painel Administrativo</h2>

            <p class="text-white">
                Visão geral da @ViewBag.NomeBarbearia
            </p>

            <hr />

            <div class="row">

                <div class="col-md-3 mb-3">

                    <a href="/Clientes"
                       class="text-decoration-none text-white">

                        <div class="card p-3 shadow-sm">

                            <h5>Clientes</h5>

                            <h2>@ViewBag.TotalClientes</h2>

                            <small class="text-white">
                                Clientes cadastrados
                            </small>

                        </div>

                    </a>

                </div>


                <div class="col-md-3 mb-3">

                    <a href="/Agenda"
                       class="text-decoration-none text-white">

                        <div class="card p-3 shadow-sm">

                            <h5>Agendamentos</h5>

                            <h2>@ViewBag.AgendamentosHoje</h2>

                            <small class="text-white">
                                Agendamentos de hoje
                            </small>

                        </div>

                    </a>

                </div>


                <div class="col-md-3 mb-3">

                    <div class="card p-3 shadow-sm">

                        <h5>Hoje</h5>

                        <h2>@ViewBag.FaturamentoHoje</h2>

                        <small class="text-white">
                            Faturamento diário
                        </small>

                    </div>

                </div>


                <div class="col-md-3 mb-3">

                    <div class="card p-3 shadow-sm">

                        <h5>Mês</h5>

                        <h2>@ViewBag.FaturamentoMes</h2>

                        <small class="text-white">
                            Faturamento mensal
                        </small>

                    </div>

                </div>

            </div>


            <div class="row mt-4">

                <div class="col-md-8">

                    <div class="card p-4 shadow-sm">

                        <h5>Agenda do Dia</h5>

                        <hr />

                        @if (agendaHoje != null && agendaHoje.Any())
                        {
                            <table class="table table-sm table-bordered">

                                <thead class="table-dark">

                                    <tr>
                                        <th>Hora</th>
                                        <th>Cliente</th>
                                        <th>Barbeiro</th>
                                        <th>Serviço</th>
                                        <th>Valor</th>
                                        <th>Status</th>
                                    </tr>

                                </thead>

                                <tbody>

                                    @foreach (var item in agendaHoje)
                                    {
                                        <tr>

                                            <td>
                                                @item.DataHora.ToString("HH:mm")
                                            </td>

                                            <td>
                                                @item.Cliente?.Nome
                                            </td>

                                            <td>
                                                @item.Barbeiro?.Nome
                                            </td>

                                            <td>
                                                @item.Servico
                                            </td>

                                            <td>
                                                R$ @item.Valor.ToString("N2")
                                            </td>

                                            <td>
                                                @item.Status
                                            </td>

                                        </tr>
                                    }

                                </tbody>

                            </table>
                        }
                        else
                        {
                            <p class="text-white">
                                Nenhum agendamento cadastrado para hoje.
                            </p>
                        }

                    </div>

                </div>


                <div class="col-md-4">

                    <div class="card p-4 shadow-sm">

                        <h5>Promoção em Destaque</h5>

                        <hr />

                        <p class="text-white">
                            @ViewBag.PromocaoDestaque
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>