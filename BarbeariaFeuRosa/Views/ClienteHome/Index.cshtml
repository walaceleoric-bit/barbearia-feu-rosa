@{
    ViewData["Title"] = "Área do Cliente";
}

<div class="container-fluid">

    <div class="row">

        <div class="col-2 bg-dark text-white vh-100 p-3">

            <div class="text-center mb-4">

                @if (ViewBag.Logo != null)
                {
                    <img src="@ViewBag.Logo"
                         style="max-width:120px;" />
                }

                <h5 class="mt-3">
                    @ViewBag.NomeBarbearia
                </h5>

            </div>

            <hr />

            <a href="/ClienteHome/Index"
               class="text-white text-decoration-none d-block mb-3">
                🏠 Início
            </a>

            <a href="/AgendamentoOnline/Index"
               class="text-white text-decoration-none d-block mb-3">
                📅 Agendar
            </a>

            <a href="/HistoricoCliente/Index"
               class="text-white text-decoration-none d-block mb-3">
                📖 Histórico
            </a>

            <a href="/ClienteHome/Contatos"
               class="text-white text-decoration-none d-block mb-3">
                💈 Contato Barbeiros
            </a>

            <a href="/Auth/Sair"
               class="text-white text-decoration-none d-block mt-5">
                🚪 Sair
            </a>

        </div>

        <div class="col-10 p-4">

            <h2 style="font-weight:700;">
                Bem-vindo, @ViewBag.NomeCliente 👋
            </h2>

            <p class="text-muted mb-4">
                Seu estilo começa aqui.
            </p>

            <hr />

            @{
                var imagens = new List<string>();

                if (ViewBag.Imagem1 != null) imagens.Add(ViewBag.Imagem1);
                if (ViewBag.Imagem2 != null) imagens.Add(ViewBag.Imagem2);
                if (ViewBag.Imagem3 != null) imagens.Add(ViewBag.Imagem3);
                if (ViewBag.Imagem4 != null) imagens.Add(ViewBag.Imagem4);
                if (ViewBag.Imagem5 != null) imagens.Add(ViewBag.Imagem5);
            }

            <style>
                .titulo-destaque {
                    font-size: 28px;
                    font-weight: 700;
                    margin-bottom: 20px;
                }

                .carrossel-destaque {
                    background: #111;
                    border-radius: 18px;
                    padding: 30px;
                    overflow: hidden;
                }

                .carrossel-area {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    gap: 18px;
                }

                .carrossel-img {
                    width: 26%;
                    height: 220px;
                    object-fit: cover;
                    border-radius: 16px;
                    opacity: .45;
                    transform: scale(.88);
                    transition: .6s;
                }

                .ativa {
                    width: 42%;
                    height: 280px;
                    opacity: 1;
                    transform: scale(1.05);
                    box-shadow: 0 0 20px rgba(255,255,255,.18);
                }

                .carrossel-legenda {
                    text-align: center;
                    margin-top: 18px;
                    font-size: 18px;
                    font-weight: 600;
                }

                .promo-card {
                    border-radius: 18px;
                    padding: 35px;
                    margin-top: 35px;
                }

                .promo-titulo {
                    font-size: 30px;
                    font-weight: 700;
                    margin-bottom: 20px;
                }

                .cta-card {
                    border-radius: 18px;
                    padding: 30px;
                    margin-top: 25px;
                }

                .servico-item {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    padding: 16px 0;
                    border-bottom: 1px solid rgba(255,255,255,.12);
                }

                .servico-nome {
                    font-size: 18px;
                    font-weight: 600;
                }

                .servico-valor {
                    font-size: 18px;
                    font-weight: 800;
                }
            </style>

            @if (imagens.Any())
            {
                <div class="titulo-destaque">
                    ✨ Destaques da Barbearia
                </div>

                <div class="carrossel-destaque mb-4">

                    <div class="carrossel-area">

                        <img id="imgAnterior"
                             class="carrossel-img" />

                        <img id="imgAtual"
                             class="carrossel-img ativa" />

                        <img id="imgProxima"
                             class="carrossel-img" />

                    </div>

                    <div class="carrossel-legenda">
                        Cortes em destaque
                    </div>

                </div>

                <script>
                    const imagensCarrossel =
                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(imagens));

                    let indiceAtual = 0;

                    function atualizarCarrossel() {
                        const total = imagensCarrossel.length;
                        const anterior = (indiceAtual - 1 + total) % total;
                        const proxima = (indiceAtual + 1) % total;

                        document.getElementById("imgAnterior").src =
                            imagensCarrossel[anterior];

                        document.getElementById("imgAtual").src =
                            imagensCarrossel[indiceAtual];

                        document.getElementById("imgProxima").src =
                            imagensCarrossel[proxima];
                    }

                    function avancarImagem() {
                        indiceAtual = (indiceAtual + 1) % imagensCarrossel.length;
                        atualizarCarrossel();
                    }

                    atualizarCarrossel();

                    setInterval(avancarImagem, 4000);
                </script>
            }

            <div class="card promo-card">

                <div class="promo-titulo">
                    🔥 Promoção Especial
                </div>

                <h4>
                    @ViewBag.Promocao
                </h4>

            </div>

            <div class="card cta-card">

                <h4>
                    📅 Pronto para renovar o visual?
                </h4>

                <p class="mt-3">
                    Agende seu horário em poucos segundos.
                </p>

                <a href="/AgendamentoOnline/Index"
                   class="btn btn-dark mt-2">

                    Agendar Agora

                </a>

            </div>

            <div class="card cta-card">

                <h4>
                    ✂ Nossos Serviços
                </h4>

                <p class="text-muted mt-2">
                    Confira os serviços disponíveis nesta barbearia.
                </p>

                <div class="mt-4">

                    @if (ViewBag.Servicos != null)
                    {
                        foreach (var servico in ViewBag.Servicos)
                        {
                            <div class="servico-item">

                                <span class="servico-nome">
                                    @servico.Nome
                                </span>

                                <strong class="servico-valor">
                                    R$ @servico.Valor.ToString("N2")
                                </strong>

                            </div>
                        }
                    }
                    else
                    {
                        <p>
                            Nenhum serviço cadastrado ainda.
                        </p>
                    }

                </div>

                <a href="/AgendamentoOnline/Index"
                   class="btn btn-success mt-4">

                    Escolher Serviço e Agendar

                </a>

            </div>

        </div>

    </div>

</div>