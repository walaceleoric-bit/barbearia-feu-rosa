@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5" style="max-width:450px;">

    <div class="text-center mb-4">
        <h2>✂ Feu Rosa</h2>
        <p class="text-muted">Acesse sua conta</p>
    </div>

    @if (ViewBag.Erro != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Erro
        </div>
    }

    <form method="post">

        <div class="mb-3">
            <label>Usuário</label>
            <input name="usuarioLogin"
                   class="form-control"
                   required />
        </div>

        <div class="mb-3">
            <label>Senha</label>
            <input name="senha"
                   type="password"
                   maxlength="6"
                   inputmode="numeric"
                   class="form-control"
                   required />
        </div>

        <button class="btn btn-dark w-100">
            Entrar
        </button>

        <a href="/Auth/Cadastro"
               class="btn btn-outline-dark w-100 mt-2">
            Criar conta
        </a>

    </form>

</div>