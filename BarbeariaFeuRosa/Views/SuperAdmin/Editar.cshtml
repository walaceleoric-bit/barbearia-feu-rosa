@model BarbeariaFeuRosa.Models.Barbearia

@{
    ViewData["Title"] = "Editar Barbearia";

    var usuarioAdm =
        ViewBag.UsuarioAdm as BarbeariaFeuRosa.Models.Usuario;
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">Editar Barbearia</h2>

        <a href="/SuperAdmin/Index" class="btn btn-outline-light">
            ← Voltar
        </a>
    </div>

    <div class="card bg-dark text-white border-secondary p-4">

        <form asp-action="Editar" asp-controller="SuperAdmin" method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Nome da Barbearia</label>
                <input asp-for="Nome" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Slug da URL</label>
                <input asp-for="Slug" class="form-control" required />

                <small class="text-secondary">
                    Exemplo: feu-rosa, barbearia-santos, stilo
                </small>
            </div>

            <div class="mb-3">
                <label class="form-label">Plano</label>
                <input asp-for="Plano" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Valor da Mensalidade</label>

                <input asp-for="ValorMensalidade"
                       class="form-control"
                       type="number"
                       step="0.01" />
            </div>

            <div class="mb-3">
                <label class="form-label">Data de Vencimento</label>

                <input asp-for="DataVencimento"
                       class="form-control"
                       type="date" />
            </div>

            <div class="mb-3">
                <label class="form-label">Observação</label>

                <textarea asp-for="Observacao"
                          class="form-control"
                          rows="4"></textarea>
            </div>


            <hr />

            <h5 class="mb-4">
                🔐 Acesso do Administrador
            </h5>


            <div class="mb-3">
                <label class="form-label">
                    Login do ADM
                </label>

                <input name="novoLoginAdm"
                       class="form-control"
                       value="@usuarioAdm?.UsuarioLogin" />
            </div>


            <div class="mb-3">
                <label class="form-label">
                    Nova senha do ADM
                </label>

                <input name="novaSenhaAdm"
                       class="form-control"
                       maxlength="6"
                       placeholder="Digite nova senha ou deixe vazio" />

                <small class="text-secondary">
                    Se deixar vazio, a senha atual será mantida.
                </small>
            </div>


            <div class="mb-3 form-check">
                <input asp-for="Ativa"
                       class="form-check-input" />

                <label class="form-check-label">
                    Barbearia ativa
                </label>
            </div>


            <div class="mb-3 form-check">
                <input asp-for="PagamentoEmDia"
                       class="form-check-input" />

                <label class="form-check-label">
                    Pagamento em dia
                </label>
            </div>


            <button type="submit"
                    class="btn btn-success">

                Salvar Alterações

            </button>

            <a href="/SuperAdmin/Index"
               class="btn btn-secondary">

                Cancelar

            </a>

        </form>

    </div>

</div>