@model List<BarbeariaFeuRosa.Models.Barbearia>

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between mb-4">

        <h2 class="text-white">
            Minhas Barbearias
        </h2>

        <div>
            <a href="/SuperAdmin/Nova" class="btn btn-success">
                + Nova
            </a>

            <a href="/SuperAdmin/Sair" class="btn btn-danger">
                Sair
            </a>
        </div>

    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Erro"]
        </div>
    }

    <table class="table table-dark table-bordered align-middle">

        <thead>
            <tr>
                <th>Nome</th>
                <th>Slug</th>
                <th>Plano</th>
                <th>Mensalidade</th>
                <th>Vencimento</th>
                <th>Pagamento</th>
                <th>Status</th>
                <th>Observação</th>
                <th width="300">Ações</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Nome</td>

                    <td>/@item.Slug</td>

                    <td>@item.Plano</td>

                    <td>
                        R$ @item.ValorMensalidade.ToString("N2")
                    </td>

                    <td>
                        @item.DataVencimento.ToString("dd/MM/yyyy")
                    </td>

                    <td>
                        @if (item.PagamentoEmDia)
                        {
                            <span class="badge bg-success">
                                Em dia
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">
                                Pendente
                            </span>
                        }
                    </td>

                    <td>
                        @if (item.Ativa)
                        {
                            <span class="badge bg-success">
                                Ativa
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Bloqueada
                            </span>
                        }
                    </td>

                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.Observacao))
                        {
                            <span>@item.Observacao</span>
                        }
                        else
                        {
                            <span class="text-muted">Sem observação</span>
                        }
                    </td>

                    <td>

                        <a href="/SuperAdmin/Editar/@item.Id"
                           class="btn btn-primary btn-sm">
                            Editar
                        </a>

                        @if (item.Ativa)
                        {
                            <a href="/SuperAdmin/Bloquear/@item.Id"
                               class="btn btn-warning btn-sm">
                                Bloquear
                            </a>
                        }
                        else
                        {
                            <a href="/SuperAdmin/Liberar/@item.Id"
                               class="btn btn-success btn-sm">
                                Liberar
                            </a>
                        }

                        <form asp-controller="SuperAdmin"
                              asp-action="Excluir"
                              asp-route-id="@item.Id"
                              method="post"
                              style="display:inline;">

                            @Html.AntiForgeryToken()

                            <button type="submit"
                                    class="btn btn-danger btn-sm"
                                    onclick="return confirm('Tem certeza que deseja excluir esta barbearia? Essa ação não pode ser desfeita.');">
                                Excluir
                            </button>

                        </form>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>