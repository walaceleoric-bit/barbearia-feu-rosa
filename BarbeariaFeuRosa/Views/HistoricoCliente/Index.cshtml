@model List<BarbeariaFeuRosa.Models.Agendamento>

@{
    ViewData["Title"] = "Meu Histórico";
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center">
        <h2>Meu Histórico</h2>

        <div>
            <a href="/HistoricoCliente/Limpar"
                   class="btn btn-danger"
                   onclick="return confirm('Deseja apagar todo o seu histórico?');">
                Limpar Histórico
            </a>

            <a href="/ClienteHome/Index" class="btn btn-outline-dark">
                ← Voltar
            </a>
        </div>
    </div>

    <hr />

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Data</th>
                <th>Barbeiro</th>
                <th>Serviço</th>
                <th>Valor</th>
                <th>Status</th>
                <th width="120">Ações</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.Barbeiro?.Nome</td>
                    <td>@item.Servico</td>
                    <td>R$ @item.Valor.ToString("N2")</td>
                    <td>@item.Status</td>
                    <td>
                        <a href="/HistoricoCliente/Excluir/@item.Id"
                               class="btn btn-sm btn-danger"
                               onclick="return confirm('Excluir este agendamento do histórico?');">
                            Excluir@model List<BarbeariaFeuRosa.Models.Agendamento>

@{
    ViewData["Title"] = "Meu Histórico";

    var avaliacoesFeitas =
        ViewBag.AvaliacoesFeitas as List<string> ?? new List<string>();
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center">
        <h2>Meu Histórico</h2>

        <div>
            <a href="/HistoricoCliente/Limpar"
               class="btn btn-danger"
               onclick="return confirm('Deseja apagar todo o seu histórico?');">
                Limpar Histórico
            </a>

            <a href="/ClienteHome/Index" class="btn btn-outline-dark">
                ← Voltar
            </a>
        </div>
    </div>

    <hr />

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Erro"]
        </div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Data</th>
                <th>Barbeiro</th>
                <th>Serviço</th>
                <th>Valor</th>
                <th>Status</th>
                <th width="220">Ações</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                var chaveAvaliacao = item.BarbeiroId + "-" + item.ClienteId;
                var jaAvaliou = avaliacoesFeitas.Contains(chaveAvaliacao);

                <tr>
                    <td>@item.DataHora.ToString("dd/MM/yyyy HH:mm")</td>

                    <td>@item.Barbeiro?.Nome</td>

                    <td>@item.Servico</td>

                    <td>R$ @item.Valor.ToString("N2")</td>

                    <td>@item.Status</td>

                    <td>
                        @if (item.Status == "Finalizado" && !jaAvaliou)
                        {
                            <a href="/HistoricoCliente/Avaliar/@item.Id"
                               class="btn btn-sm btn-warning mb-1">
                                ⭐ Avaliar
                            </a>
                        }
                        else if (item.Status == "Finalizado" && jaAvaliou)
                        {
                            <span class="badge bg-success mb-1">
                                Avaliado
                            </span>
                        }

                        <a href="/HistoricoCliente/Excluir/@item.Id"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Excluir este agendamento do histórico?');">
                            Excluir
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>