@{
    ViewData["Title"] = "Financeiro";

    var movimentacoes = ViewBag.Movimentacoes as List<BarbeariaFeuRosa.Models.Agendamento>;
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center">
        <h2>Financeiro</h2>

        <a href="/Dashboard" class="btn btn-outline-dark">
            ← Voltar ao Painel
        </a>
    </div>

    <hr />

    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Faturamento Hoje</h5>
                <h2>@ViewBag.FaturamentoHoje</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Faturamento do Mês</h5>
                <h2>@ViewBag.FaturamentoMes</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Comissões</h5>
                <h2>@ViewBag.Comissoes</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Agendamentos</h5>
                <h2>@ViewBag.TotalAgendamentos</h2>
            </div>
        </div>

    </div>

    <div class="card p-4 shadow-sm">
        <h5>Movimentações Financeiras</h5>
        <hr />

        @if (movimentacoes != null && movimentacoes.Any())
        {
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Data</th>
                        <th>Cliente</th>
                        <th>Barbeiro</th>
                        <th>Serviço</th>
                        <th>Valor</th>
                        <th>Comissão</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in movimentacoes)
                    {
                        var comissao = item.Valor * (item.Barbeiro != null ? item.Barbeiro.ComissaoPercentual : 0) / 100;

                        <tr>
                            <td>@item.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Cliente?.Nome</td>
                            <td>@item.Barbeiro?.Nome</td>
                            <td>@item.Servico</td>
                            <td>R$ @item.Valor.ToString("N2")</td>
                            <td>R$ @comissao.ToString("N2")</td>
                            <td>@item.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Nenhuma movimentação financeira encontrada.</p>
        }
    </div>

</div>