@model BarbeariaFeuRosa.Models.Barbeiro

@{
    ViewData["Title"] = "Editar Barbeiro";
}

<div class="container p-4">

    <div class="d-flex justify-content-between align-items-center">
        <h2>Editar Barbeiro</h2>

        <a href="/Barbeiros" class="btn btn-outline-dark">
            ← Voltar
        </a>
    </div>

    <hr />

    <form asp-action="Editar" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="FotoUrl" />

        @if (!string.IsNullOrWhiteSpace(Model.FotoUrl))
        {
            <div class="mb-3">
                <label>Foto Atual</label>
                <br />
                <img src="@Model.FotoUrl"
                     class="rounded"
                     style="max-width:140px; max-height:140px; object-fit:cover;" />
            </div>
        }

        <div class="mb-3">
            <label>Trocar Foto</label>
            <input type="file" name="foto" class="form-control" accept="image/*" />
        </div>

        <div class="mb-3">
            <label>Nome</label>
            <input asp-for="Nome" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Telefone / WhatsApp</label>
            <input asp-for="Telefone" class="form-control" placeholder="Ex: 27999999999" />
        </div>

        <div class="mb-3">
            <label>Especialidade</label>
            <input asp-for="Especialidade" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Comissão %</label>
            <input asp-for="ComissaoPercentual" class="form-control" />
        </div>

        <div class="form-check mb-3">
            <input asp-for="Ativo" class="form-check-input" />
            <label class="form-check-label" asp-for="Ativo">
                Barbeiro ativo
            </label>
        </div>

        <button type="submit" class="btn btn-dark">
            Salvar Alterações
        </button>

        <a href="/Barbeiros" class="btn btn-secondary">
            Cancelar
        </a>

    </form>

</div>