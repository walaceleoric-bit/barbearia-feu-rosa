@model BarbeariaFeuRosa.Models.Barbeiro

@{
    ViewData["Title"] = "Editar Barbeiro";

    var usuarioBarbeiro =
        ViewBag.UsuarioBarbeiro as BarbeariaFeuRosa.Models.Usuario;
}

<div class="container p-4">

    <div class="d-flex justify-content-between align-items-center">
        <h2>Editar Barbeiro</h2>

        <a href="/Barbeiros" class="btn btn-outline-dark">
            ← Voltar
        </a>
    </div>

    <hr />

    <form asp-action="Editar" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="FotoUrl" />

        @if (!string.IsNullOrWhiteSpace(Model.FotoUrl))
        {
            <div class="mb-3">
                <label>Foto Atual</label>
                <br />
                <img src="@Model.FotoUrl"
                     class="rounded"
                     style="max-width:140px; max-height:140px; object-fit:cover;" />
            </div>
        }

        <div class="mb-3">
            <label>Trocar Foto</label>
            <input type="file"
                   name="foto"
                   class="form-control"
                   accept="image/*" />
        </div>

        <div class="mb-3">
            <label>Nome</label>
            <input asp-for="Nome" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Telefone / WhatsApp</label>
            <input asp-for="Telefone"
                   class="form-control"
                   placeholder="Ex: 27999999999" />
        </div>

        <div class="mb-3">
            <label>Especialidade</label>
            <input asp-for="Especialidade"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label>Comissão %</label>
            <input asp-for="ComissaoPercentual"
                   class="form-control" />
        </div>

        <hr />

        <h5 class="mb-3">
            🔐 Acesso do Barbeiro
        </h5>

        <div class="mb-3">
            <label>Login do Barbeiro</label>

            <input name="usuarioLogin"
                   class="form-control"
                   value="@usuarioBarbeiro?.UsuarioLogin"
                   placeholder="Ex: joao" />
        </div>

        <div class="mb-3">
            <label>Nova senha do Barbeiro</label>

            <input name="novaSenha"
                   class="form-control"
                   maxlength="6"
                   placeholder="Digite nova senha ou deixe vazio" />

            <small class="text-muted">
                Se deixar vazio, a senha atual será mantida.
            </small>
        </div>


        <div class="mb-3">

            <label>Status do Barbeiro</label>

            <select name="statusAtivo"
                    class="form-control">

                @if (Model.Ativo)
                {
                    <option value="true" selected>
                        ✅ Ativo
                    </option>

                    <option value="false">
                        ❌ Inativo
                    </option>
                }
                else
                {
                    <option value="true">
                        ✅ Ativo
                    </option>

                    <option value="false" selected>
                        ❌ Inativo
                    </option>
                }

            </select>

        </div>


        <button type="submit"
                class="btn btn-dark">

            Salvar Alterações

        </button>

        <a href="/Barbeiros"
           class="btn btn-secondary">

            Cancelar

        </a>

    </form>

</div>