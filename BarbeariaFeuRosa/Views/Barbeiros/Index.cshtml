@model List<BarbeariaFeuRosa.Models.Barbeiro>

@{
    ViewData["Title"] = "Barbeiros";
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center">
        <h2>Barbeiros</h2>

        <a href="/Dashboard" class="btn btn-outline-dark">
            ← Voltar ao Painel
        </a>
    </div>

    <hr />

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    <a asp-action="Novo" class="btn btn-dark mb-3">
        + Novo Barbeiro
    </a>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Nome</th>
                <th>Telefone</th>
                <th>Especialidade</th>
                <th>Comissão</th>
                <th>Status</th>
                <th width="180">Ações</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Nome</td>

                    <td>@item.Telefone</td>

                    <td>@item.Especialidade</td>

                    <td>@item.ComissaoPercentual %</td>

                    <td>
                        @(item.Ativo ? "Ativo" : "Inativo")
                    </td>

                    <td>

                        <a asp-action="Editar"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-primary">
                            Editar
                        </a>

                        <a asp-action="Excluir"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger"
                               onclick="return confirm('Deseja excluir?')">
                            Excluir
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>